# Copy this file to .env.local for local development. Do not commit real credentials.

# Core app
APP_URL=http://localhost:3000
APP_IFRAME_BASE_URL=http://localhost:3000
APP_API_BASE_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/pepclub_payments
SALEOR_API_URL=https://your-saleor.example/graphql/
APL=postgres

# Payment orchestration
DEFAULT_PAYMENT_PROVIDER=nowpayments
ENABLE_NOWPAYMENTS=true
ENABLE_MOONPAY=true
ENABLE_RAMPNETWORK=true

# Compliance integration
# metadata: read paymentGateway.data and Saleor metadata/privateMetadata
# api: call {COMPLIANCE_APP_INTERNAL_URL}/api/internal/compliance/status with x-pepclub-shared-secret
COMPLIANCE_VALIDATION_MODE=metadata
COMPLIANCE_APP_INTERNAL_URL=
COMPLIANCE_APP_SHARED_SECRET=
REQUIRE_SIGNATURE_COMPLETION=false

# NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_ENV=sandbox
FRANKFURTER_API_URL=https://api.frankfurter.dev/v1/latest
FX_CACHE_TTL_SECONDS=3600
FX_STALE_TTL_SECONDS=86400
FX_SOURCE_CURRENCY=THB
FX_TARGET_CURRENCY=USD

# MoonPay
MOONPAY_PUBLISHABLE_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_KEY=
MOONPAY_ENV=sandbox
MOONPAY_DEFAULT_BASE_CURRENCY=usd
MOONPAY_DEFAULT_QUOTE_CURRENCY=btc
MOONPAY_DEFAULT_WALLET_ADDRESS=
MOONPAY_RETURN_URL=https://your-storefront.example/payments/moonpay/return
MOONPAY_CANCEL_URL=https://your-storefront.example/payments/moonpay/cancel

# Ramp Network
RAMPNETWORK_API_KEY=
RAMPNETWORK_WEBHOOK_SECRET=
RAMPNETWORK_ENV=sandbox
RAMPNETWORK_HOST_APP_NAME=Pepclub
RAMPNETWORK_HOST_LOGO_URL=https://your-assets.example/pepclub-logo.png
RAMPNETWORK_DEFAULT_ASSET=ETH
RAMPNETWORK_DEFAULT_FIAT_CURRENCY=USD
RAMPNETWORK_DEFAULT_FIAT_VALUE=100
RAMPNETWORK_DEFAULT_USER_ADDRESS=
RAMPNETWORK_FINAL_URL=https://your-storefront.example/payments/rampnetwork/final

# Hosted payment redirects
PAYMENT_SUCCESS_URL=https://your-storefront.example/checkout/payment-success
PAYMENT_CANCEL_URL=https://your-storefront.example/checkout/payment-cancelled
PAYMENT_STATUS_URL=https://your-storefront.example/checkout/payment-status
